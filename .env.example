# ====================================================================
# E-Commerce Platform - Environment Variables Example
# Copy this file to .env and fill in your values
# ====================================================================

# ─── Database ────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword
DB_USERNAME=ecommerce
DB_PASSWORD=ecommerce123

# ─── JWT Authentication ───────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-key-must-be-at-least-256-bits-long-for-security
JWT_EXPIRATION=86400000

# ─── Stripe Payment ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── Email / SMTP ─────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ─── Frontend ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── AWS (for production deployment) ─────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ecommerce-platform-frontend
AWS_CLOUDFRONT_DISTRIBUTION_ID=your_cloudfront_distribution_id
AWS_ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
AWS_ECS_CLUSTER=ecommerce-cluster
AWS_ECS_SERVICE=ecommerce-backend
